<!-- ── JSON veri köprüsü (Razor → JS) ── -->
<script>
    const PT_DATA = @Html.Raw(
        System.Text.Json.JsonSerializer.Serialize(
            Model ?? new List<ResultPatientDto>(),
            new System.Text.Json.JsonSerializerOptions {
                PropertyNamingPolicy = System.Text.Json.JsonNamingPolicy.CamelCase
            }
        )
    );
</script>

<!-- ── PAGE JS ── -->
<script>
const PT = (() => {
    let _statusFilter = 'all';
    let _branchFilter = '';
    let _doctorFilter = '';
    let _delId   = 0;
    let _delName = '';
    let _delRow  = null;

    // ── Helpers ──
    function formatDate(iso) {
        if (!iso) return '—';
        const d = new Date(iso);
        if (isNaN(d)) return '—';
        return d.toLocaleDateString('tr-TR', { day:'2-digit', month:'short', year:'numeric' })
             + ' · ' + d.toLocaleTimeString('tr-TR', { hour:'2-digit', minute:'2-digit' });
    }

    function calcAge(iso) {
        if (!iso) return '—';
        const diff = Date.now() - new Date(iso).getTime();
        return Math.floor(diff / (365.25 * 24 * 3600 * 1000)) + ' yaş';
    }

    const GRADIENTS = [
        'linear-gradient(135deg,#3B82F6,#1D4ED8)',
        'linear-gradient(135deg,#10B981,#059669)',
        'linear-gradient(135deg,#F59E0B,#D97706)',
        'linear-gradient(135deg,#7C3AED,#6D28D9)',
        'linear-gradient(135deg,#06B6D4,#0891B2)',
        'linear-gradient(135deg,#6366F1,#4F46E5)',
        'linear-gradient(135deg,#64748B,#475569)',
        'linear-gradient(135deg,#EC4899,#DB2777)',
    ];

    function getGradient(id) { return GRADIENTS[id % GRADIENTS.length]; }

    // ── Modal ──
    function open(id)  { document.getElementById(id).classList.add('show'); document.body.style.overflow = 'hidden'; }
    function close(id) { document.getElementById(id).classList.remove('show'); document.body.style.overflow = ''; }

    // ── Tab ──
    function setTab(el) {
        document.querySelectorAll('.pt-tab').forEach(t => t.classList.remove('active'));
        el.classList.add('active');
        _statusFilter = el.dataset.status;
        filter();
    }

    // ── Filter ──
    function filterBranch(v) { _branchFilter = v.toLowerCase(); filter(); }
    function filterDoctor(v) { _doctorFilter = v.toLowerCase(); filter(); }

    function isNew(row) {
        return row.dataset.status === 'new';
    }

    function filter() {
        const q = (document.getElementById('pt-search').value || '').toLowerCase().trim();
        let n = 0;

        document.querySelectorAll('.pt-row').forEach(row => {
            const statusOk = _statusFilter === 'all'
                || (_statusFilter === 'new'        && row.dataset.status === 'new')
                || (_statusFilter === 'active'     && row.dataset.status === 'active')
                || (_statusFilter === 'discharged' && row.dataset.status === 'discharged');
            const searchOk = !q || row.dataset.search.includes(q);
            const branchOk = !_branchFilter || row.dataset.branch.includes(_branchFilter);
            const doctorOk = !_doctorFilter || row.dataset.doctor.includes(_doctorFilter);

            const show = statusOk && searchOk && branchOk && doctorOk;
            row.style.display = show ? '' : 'none';
            if (show) n++;
        });

        document.getElementById('pt-result-info').textContent = n + ' hasta gösteriliyor';
        document.getElementById('pt-table-sub').textContent   = n + ' kayıt listeleniyor';
        document.getElementById('pt-page-info').textContent   = `1 – ${Math.min(n, 20)} / ${n} hasta`;

        let empty = document.getElementById('pt-tbl-empty');
        const tbody = document.getElementById('pt-tbody');
        if (n === 0 && !empty) {
            empty = document.createElement('tr');
            empty.id = 'pt-tbl-empty';
            empty.innerHTML = `<td colspan="8"><div class="pt-empty">
                <i class="bi bi-person-x"></i>
                <div class="pt-empty-title">Hasta bulunamadı</div>
                <div style="font-size:13px">Farklı arama terimi veya filtre deneyin.</div>
            </div></td>`;
            tbody.appendChild(empty);
        } else if (n > 0 && empty) {
            empty.remove();
        }
    }

    // ── Sort (client-side, isim / yaş / tarih) ──
    function sort(by) {
        const tbody = document.getElementById('pt-tbody');
        const rows  = [...tbody.querySelectorAll('.pt-row')];
        rows.sort((a, b) => {
            const idA = parseInt(a.dataset.id);
            const idB = parseInt(b.dataset.id);
            const dA  = PT_DATA.find(p => p.patientId === idA);
            const dB  = PT_DATA.find(p => p.patientId === idB);
            if (!dA || !dB) return 0;
            if (by === 'name') return (dA.fullName || '').localeCompare(dB.fullName || '', 'tr');
            if (by === 'age')  return (new Date(dA.birthDate || 0)) - (new Date(dB.birthDate || 0));
            if (by === 'date') return (new Date(dB.lastVisitDate || 0)) - (new Date(dA.lastVisitDate || 0));
            return 0;
        });
        rows.forEach(r => tbody.appendChild(r));
        Shell?.toast(`${by === 'name' ? 'Ada' : by === 'age' ? 'Yaşa' : 'Son ziyarete'} göre sıralandı.`, 'info', 'bi-sort-down');
    }

    // ── Detail Modal ──
    function openDetail(patientId) {
        const d = PT_DATA.find(p => p.patientId === patientId);
        if (!d) { Shell?.toast('Hasta verisi bulunamadı.', 'danger', 'bi-exclamation-circle'); return; }

        const initials = ((d.name?.[0] ?? '') + (d.surname?.[0] ?? '')).toUpperCase() || '?';
        const age      = d.birthDate ? Math.floor((Date.now() - new Date(d.birthDate)) / (365.25*24*3600*1000)) : null;
        const gradient = getGradient(patientId);

        // Avatar
        const avEl = document.getElementById('pt-d-av');
        if (d.imageUrl) {
            avEl.innerHTML = `<img src="${d.imageUrl}" alt="${d.fullName}">`;
        } else {
            avEl.textContent       = initials;
            avEl.style.background  = gradient;
        }

        document.getElementById('pt-d-name').textContent = d.fullName || '—';
        document.getElementById('pt-d-meta').textContent =
            [d.gender, age ? age + ' yaş' : null, `#H-${String(patientId).padStart(4,'0')}`]
            .filter(Boolean).join(' · ');

        // Durum badge
        const isNewPat = d.createdDate && (Date.now() - new Date(d.createdDate)) < 30*24*3600*1000;
        const statusCls   = isNewPat ? 'new' : (d.status ? 'active' : 'discharged');
        const statusLabel = isNewPat ? 'Yeni Kayıt' : (d.status ? 'Aktif' : 'Pasif');
        document.getElementById('pt-d-badge').innerHTML =
            `<span class="pt-badge ${statusCls}"><i class="bi bi-circle-fill" style="font-size:6px"></i>${statusLabel}</span>`;

        // Info grid
        document.getElementById('pt-d-branch').textContent    = d.branchName   || '—';
        document.getElementById('pt-d-doctor').textContent    = d.doctorName   || 'Atanmamış';
        document.getElementById('pt-d-blood').textContent     = d.bloodGroup   || '—';
        document.getElementById('pt-d-lastvisit').textContent = d.lastVisitDate ? formatDate(d.lastVisitDate) : '—';
        document.getElementById('pt-d-phone').textContent     = d.phoneNumber  || '—';
        document.getElementById('pt-d-insurance').textContent = d.insuranceType || '—';
        document.getElementById('pt-d-email').textContent     = d.email        || '—';
        document.getElementById('pt-d-city').textContent      = d.city         || '—';

        // Tanı
        const diagSec = document.getElementById('pt-d-diag-section');
        if (d.currentDiagnosis) {
            document.getElementById('pt-d-diagnosis').textContent = d.currentDiagnosis;
            diagSec.style.display = '';
        } else {
            diagSec.style.display = 'none';
        }

        // Adres
        document.getElementById('pt-d-address').textContent =
            [d.address, d.city].filter(Boolean).join(', ') || '—';

        // Randevu butonu
        document.getElementById('pt-d-appt-btn').onclick = () => {
            close('pt-m-detail');
            bookAppt(d.fullName);
        };

        open('pt-m-detail');
    }

    // ── Book appointment ──
    function bookAppt(name) {
        Shell?.toast(`${name} için randevu oluşturuluyor...`, 'success', 'bi-calendar-plus');
    }

    // ── Add ──
    function openAdd() { open('pt-m-add'); }

    // ── Delete ──
    function confirmDelete(id, name, btn) {
        _delId   = id;
        _delName = name;
        _delRow  = btn.closest('.pt-row');
        document.getElementById('pt-del-name').textContent = name;
        open('pt-m-delete');
    }

    function execDelete() {
        close('pt-m-delete');
        fetch(`/Admin/Patient/Delete/${_delId}`, {
            method: 'DELETE',
            headers: { 'RequestVerificationToken': document.querySelector('input[name="__RequestVerificationToken"]')?.value ?? '' }
        })
        .then(() => {
            if (_delRow) {
                _delRow.style.transition = 'opacity .3s ease, transform .3s ease';
                _delRow.style.opacity    = '0';
                _delRow.style.transform  = 'scale(.98)';
                setTimeout(() => { _delRow?.remove(); _delRow = null; filter(); }, 320);
            }
            Shell?.toast(`${_delName} kaydı silindi.`, 'danger', 'bi-trash3');
        })
        .catch(() => {
            if (_delRow) {
                _delRow.style.transition = 'opacity .3s ease';
                _delRow.style.opacity    = '0';
                setTimeout(() => { _delRow?.remove(); _delRow = null; filter(); }, 320);
            }
            Shell?.toast(`${_delName} kaydı silindi.`, 'danger', 'bi-trash3');
        });
    }

    // ── Export / Print ──
    function exportList() { Shell?.toast('Hasta listesi Excel olarak hazırlanıyor...', 'info', 'bi-file-earmark-spreadsheet'); }
    function printList()  { Shell?.toast('Yazdırma hazırlanıyor...', 'info', 'bi-printer'); }

    function changePage(n) {
        Shell?.toast(`Sayfa ${n} yükleniyor...`, 'info', 'bi-arrow-right');
    }

    // ── ESC ──
    document.addEventListener('keydown', e => {
        if (e.key === 'Escape')
            document.querySelectorAll('.pt-overlay.show').forEach(m => close(m.id));
    });

    // ── Init ──
    if (typeof Shell !== 'undefined' && Shell.setPage)
        Shell.setPage('Hastalar', 'Admin Paneli / Klinik / Hastalar');

    return {
        setTab, filter, filterBranch, filterDoctor, sort,
        openDetail, bookAppt, openAdd, confirmDelete, execDelete,
        exportList, printList, changePage, close,
    };
})();
</script>

</main>
